{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FurLab: Start DXF Server",
      "type": "shell",
      "command": "node src/server.js",
      "options": {
        "cwd": "f:/FURLAB/dev/furlab-web-plugin",
        "env": {
          "HOST": "127.0.0.1",
          "PORT": "5600",
          "FURLAB_DB_PATH": "F:/FURLAB/dev/furlab-access/БД/Furlab 1.accdb"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[furlab-web-plugin\\]",
          "endsPattern": "^\\[furlab-web-plugin\\] db="
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
